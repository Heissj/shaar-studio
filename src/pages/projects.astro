---
import Layout from '../layouts/Layout.astro';
import projectsData from '../data/projects.json';
---
<Layout title="Projects — SHAAR Studio" activeNav="projects">
  <div class="projects-hero">
    <h1>Projects</h1>
    <p>{projectsData.subtitle}</p>
  </div>
  <div class="projects-grid">
    {projectsData.projects.map(project => (
      <a class={`project-card reveal ${project.status === 'Coming Soon' ? 'coming-soon' : ''}`}
         href={project.link || '#'}>
        <div class="project-card-img">
          {project.cover ? (
            <img src={project.cover} alt={project.title} />
          ) : (
            <div class="placeholder-bg"><span>{project.status === 'Coming Soon' ? 'Coming Soon' : 'Cover'}</span></div>
          )}
        </div>
        <div class="project-card-body">
          <div class="project-card-label">{project.label}</div>
          <h3>{project.title}</h3>
          <p>{project.description}</p>
          <div class="project-card-meta">
            <span>{project.period}</span>
            <span>{project.location}</span>
          </div>
          <div class={`project-card-status ${project.status === 'In Development' ? 'active-status' : ''}`}>
            {project.status}
          </div>
        </div>
      </a>
    ))}
  </div>
</Layout>
