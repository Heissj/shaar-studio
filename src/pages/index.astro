---
import Layout from '../layouts/Layout.astro';
import homeData from '../data/home.json';
import { getCollection } from 'astro:content';

const photos = await getCollection('gallery');
const featured = photos.filter(p => p.data.page === 'featured');
---
<Layout activeNav="home">
  <section class="hero">
    <p class="hero-subtitle">{homeData.subtitle}</p>
    <h1>The City<br><em>Revealed</em></h1>
    <p class="hero-tagline">{homeData.tagline}</p>
    <div class="hero-scroll"><span>Scroll</span><div class="scroll-line"></div></div>
  </section>

  <div class="cinema-wrapper" id="cinemaWrapper">
    <section class="cinema" id="cinema">
      <!--
        HOW TO ADD YOUR SLIDES:
        1. Drop your photos into the public/images/ folder
        2. Name them slide-1.jpg, slide-2.jpg, etc.
        3. Update the src, data-title, and data-location below
      -->
      <div class="cinema-slide active" data-title="Morning Market" data-location="Boston, 2018">
        <div class="slide-bg"><img src="/images/slide-1.jpg" alt="Morning Market" onerror="this.style.display='none';this.parentElement.innerHTML='<div class=placeholder-bg><span>Add slide-1.jpg to public/images/</span></div>'" /></div>
      </div>
      <div class="cinema-slide" data-title="The Bread Seller" data-location="Boston, 2019">
        <div class="slide-bg"><img src="/images/slide-2.jpg" alt="The Bread Seller" onerror="this.style.display='none';this.parentElement.innerHTML='<div class=placeholder-bg><span>Add slide-2.jpg to public/images/</span></div>'" /></div>
      </div>
      <div class="cinema-slide" data-title="Winter Crossroads" data-location="Boston, 2020">
        <div class="slide-bg"><img src="/images/slide-3.jpg" alt="Winter Crossroads" onerror="this.style.display='none';this.parentElement.innerHTML='<div class=placeholder-bg><span>Add slide-3.jpg to public/images/</span></div>'" /></div>
      </div>
      <div class="cinema-slide" data-title="After the Rain" data-location="Boston, 2018">
        <div class="slide-bg"><img src="/images/slide-4.jpg" alt="After the Rain" onerror="this.style.display='none';this.parentElement.innerHTML='<div class=placeholder-bg><span>Add slide-4.jpg to public/images/</span></div>'" /></div>
      </div>
      <div class="cinema-slide" data-title="Departure" data-location="Boston, 2021">
        <div class="slide-bg"><img src="/images/slide-5.jpg" alt="Departure" onerror="this.style.display='none';this.parentElement.innerHTML='<div class=placeholder-bg><span>Add slide-5.jpg to public/images/</span></div>'" /></div>
      </div>

      <div class="cinema-caption">
        <div class="cinema-caption-text">
          <div class="cinema-number" id="cinemaNumber">01 / 05</div>
          <h2 id="cinemaTitle" class="visible">Morning Market</h2>
          <p id="cinemaLocation" class="visible">Kabul, 2018</p>
        </div>
        <div class="cinema-caption-right">
          <div class="cinema-indicators" id="cinemaIndicators">
            <button class="cinema-ind active" data-slide="0"></button>
            <button class="cinema-ind" data-slide="1"></button>
            <button class="cinema-ind" data-slide="2"></button>
            <button class="cinema-ind" data-slide="3"></button>
            <button class="cinema-ind" data-slide="4"></button>
          </div>
          <div class="cinema-nav">
            <button id="cinemaPrev">&#8592;</button>
            <button id="cinemaNext">&#8594;</button>
          </div>
        </div>
      </div>
      <div class="cinema-progress"><div class="cinema-progress-bar" id="cinemaBar"></div></div>
    </section>
  </div>

  <section class="strip-section">
    <div class="strip-header">
      <div class="section-label reveal">More Work</div>
      <span class="strip-count">{featured.length > 0 ? featured.length + ' Photographs' : 'Upload photos via CMS'}</span>
    </div>
    <div class="strip-container">
      <div class="strip-track" id="stripTrack">
        {featured.length > 0 ? (
          featured.map(photo => (
            <div class="strip-card">
              <div class="strip-card-img"><img src={photo.data.image} alt={photo.data.title} loading="lazy" /></div>
              <div class="strip-card-info"><h3>{photo.data.title}</h3><span>{photo.data.location}</span></div>
            </div>
          ))
        ) : (
          <>
            <div class="strip-card"><div class="strip-card-img"><div class="placeholder-bg" style="width:100%;height:100%"><span>Photo</span></div></div><div class="strip-card-info"><h3>The Carpenter</h3><span>Kabul, 2019</span></div></div>
            <div class="strip-card"><div class="strip-card-img"><div class="placeholder-bg" style="width:100%;height:100%"><span>Photo</span></div></div><div class="strip-card-info"><h3>Window Light</h3><span>Kabul, 2017</span></div></div>
            <div class="strip-card"><div class="strip-card-img"><div class="placeholder-bg" style="width:100%;height:100%"><span>Photo</span></div></div><div class="strip-card-info"><h3>Blue Hour</h3><span>Boston, 2025</span></div></div>
            <div class="strip-card"><div class="strip-card-img"><div class="placeholder-bg" style="width:100%;height:100%"><span>Photo</span></div></div><div class="strip-card-info"><h3>Tea House</h3><span>Kabul, 2020</span></div></div>
            <div class="strip-card"><div class="strip-card-img"><div class="placeholder-bg" style="width:100%;height:100%"><span>Photo</span></div></div><div class="strip-card-info"><h3>Somerville Walk</h3><span>Boston, 2026</span></div></div>
            <div class="strip-card"><div class="strip-card-img"><div class="placeholder-bg" style="width:100%;height:100%"><span>Photo</span></div></div><div class="strip-card-info"><h3>Dusk Market</h3><span>Kabul, 2018</span></div></div>
            <div class="strip-card"><div class="strip-card-img"><div class="placeholder-bg" style="width:100%;height:100%"><span>Photo</span></div></div><div class="strip-card-info"><h3>Commute</h3><span>Kabul, 2020</span></div></div>
            <div class="strip-card"><div class="strip-card-img"><div class="placeholder-bg" style="width:100%;height:100%"><span>Photo</span></div></div><div class="strip-card-info"><h3>Old Quarter</h3><span>Kabul, 2017</span></div></div>
          </>
        )}
      </div>
    </div>
  </section>

  <section class="cta-band">
    <div class="section-label" style="justify-content:center;margin-bottom:2rem"><span style="opacity:0.7">Latest Project</span></div>
    <h2>{homeData.ctaHeading.split(' ')[0]} <em>{homeData.ctaHeading.split(' ').slice(1).join(' ')}</em></h2>
    <p>{homeData.ctaText}</p>
    <a class="btn" href="/kabul-streets" style="margin-right:1rem">Explore the Project</a>
    <a class="btn" href="/projects" style="border-color:var(--text-dim);color:var(--text-muted)">View All Projects</a>
  </section>

  <script is:inline>
    // ═══ CINEMA (scroll-driven) ═══
    var slides = document.querySelectorAll('.cinema-slide');
    var indicators = document.querySelectorAll('.cinema-ind');
    var bar = document.getElementById('cinemaBar');
    var cinemaWrapper = document.getElementById('cinemaWrapper');
    var currentSlide = 0;
    var totalSlides = slides.length;

    function goSlide(idx, progress) {
      var changed = idx !== currentSlide;
      currentSlide = idx;
      slides.forEach(function(s, i) { s.classList.toggle('active', i === idx); });
      indicators.forEach(function(ind, i) { ind.classList.toggle('active', i === idx); });
      if (progress !== undefined) {
        var segSize = 1 / totalSlides;
        var localProgress = Math.max(0, Math.min(1, (progress - idx * segSize) / segSize));
        slides[idx].querySelector('.slide-bg').style.transform = 'scale(' + (1 + localProgress * 0.1) + ')';
      }
      if (changed) {
        var t = document.getElementById('cinemaTitle');
        var l = document.getElementById('cinemaLocation');
        var n = document.getElementById('cinemaNumber');
        t.classList.remove('visible'); l.classList.remove('visible');
        setTimeout(function() {
          t.textContent = slides[idx].dataset.title;
          l.textContent = slides[idx].dataset.location;
          n.textContent = String(idx + 1).padStart(2, '0') + ' / ' + String(totalSlides).padStart(2, '0');
          t.classList.add('visible'); l.classList.add('visible');
        }, 100);
      }
    }

    var scrollTicking = false;
    window.addEventListener('scroll', function() {
      if (!scrollTicking) { scrollTicking = true; requestAnimationFrame(function() {
        if (!cinemaWrapper) return;
        var rect = cinemaWrapper.getBoundingClientRect();
        var wH = cinemaWrapper.offsetHeight - window.innerHeight;
        if (wH <= 0) return;
        var progress = Math.max(0, Math.min(1, -rect.top / wH));
        bar.style.width = (progress * 100) + '%';
        goSlide(Math.min(Math.floor(progress * totalSlides), totalSlides - 1), progress);
        scrollTicking = false;
      }); }
    });

    document.getElementById('cinemaNext').addEventListener('click', function() {
      var next = (currentSlide + 1) % totalSlides;
      var seg = (cinemaWrapper.offsetHeight - window.innerHeight) / totalSlides;
      window.scrollTo({ top: cinemaWrapper.offsetTop + next * seg, behavior: 'smooth' });
    });
    document.getElementById('cinemaPrev').addEventListener('click', function() {
      var prev = (currentSlide - 1 + totalSlides) % totalSlides;
      var seg = (cinemaWrapper.offsetHeight - window.innerHeight) / totalSlides;
      window.scrollTo({ top: cinemaWrapper.offsetTop + prev * seg, behavior: 'smooth' });
    });
    indicators.forEach(function(ind) {
      ind.addEventListener('click', function() {
        var idx = parseInt(this.dataset.slide);
        var seg = (cinemaWrapper.offsetHeight - window.innerHeight) / totalSlides;
        window.scrollTo({ top: cinemaWrapper.offsetTop + idx * seg, behavior: 'smooth' });
      });
    });

    // ═══ STRIP (auto-drift + momentum drag) ═══
    var track = document.getElementById('stripTrack');
    var isDragging = false, dragStartX = 0, dragScrollLeft = 0;
    var velocity = 0, lastX = 0, lastTime = 0, momentumId = null;
    var FRICTION = 0.94, MIN_VEL = 0.3;
    var driftPaused = false, driftDir = 1;

    var driftInterval = setInterval(function() {
      if (!driftPaused && !isDragging && !momentumId && track) {
        track.scrollLeft += 0.5 * driftDir;
        if (track.scrollLeft >= track.scrollWidth - track.clientWidth - 2) driftDir = -1;
        if (track.scrollLeft <= 2) driftDir = 1;
      }
    }, 16);

    if (track) {
      track.addEventListener('mouseenter', function() { driftPaused = true; });
      track.addEventListener('mouseleave', function() { if (!isDragging) driftPaused = false; });
    }

    function stopMomentum() { if (momentumId) { cancelAnimationFrame(momentumId); momentumId = null; } }
    function applyMomentum() {
      if (Math.abs(velocity) < MIN_VEL) { momentumId = null; driftPaused = false; return; }
      if (track) track.scrollLeft -= velocity;
      velocity *= FRICTION;
      momentumId = requestAnimationFrame(applyMomentum);
    }
    function onDragStart(x) { stopMomentum(); isDragging = true; driftPaused = true; dragStartX = x; dragScrollLeft = track ? track.scrollLeft : 0; lastX = x; lastTime = performance.now(); velocity = 0; if (track) track.classList.add('grabbing'); }
    function onDragMove(x) { if (!isDragging || !track) return; var now = performance.now(), dt = now - lastTime; if (dt > 0) velocity = (x - lastX) * (16 / dt); lastX = x; lastTime = now; track.scrollLeft = dragScrollLeft - (x - dragStartX); }
    function onDragEnd() { if (!isDragging) return; isDragging = false; if (track) track.classList.remove('grabbing'); velocity *= 1.2; if (Math.abs(velocity) > MIN_VEL) momentumId = requestAnimationFrame(applyMomentum); else driftPaused = false; }

    if (track) track.addEventListener('mousedown', function(e) { e.preventDefault(); onDragStart(e.pageX); });
    window.addEventListener('mousemove', function(e) { if (isDragging) { e.preventDefault(); onDragMove(e.pageX); } });
    window.addEventListener('mouseup', onDragEnd);
    if (track) track.addEventListener('touchstart', function(e) { onDragStart(e.touches[0].pageX); }, { passive: true });
    window.addEventListener('touchmove', function(e) { if (isDragging) onDragMove(e.touches[0].pageX); }, { passive: true });
    window.addEventListener('touchend', onDragEnd);
  </script>
</Layout>