---
import Layout from '../../layouts/Layout.astro';
import journalData from '../../data/journal.json';
import { getCollection } from 'astro:content';

const posts = (await getCollection('journal')).sort((a, b) => 
  new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);
---
<Layout title="Journal — SHAAR Studio" activeNav="journal">
  <div class="blog-hero">
    <h1>Journal</h1>
    <p>{journalData.subtitle}</p>
  </div>
  <div class="blog-grid">
    {posts.length > 0 ? (
      posts.map(post => (
        <a class="blog-card" href={`/journal/${post.slug}`}>
          <div class="blog-card-img">
            {post.data.cover ? (
              <img src={post.data.cover} alt={post.data.title} loading="lazy" />
            ) : (
              <div class="placeholder-bg" style="width:100%;height:100%"><span>Cover</span></div>
            )}
          </div>
          <div class="blog-card-text">
            <div class="blog-date">{new Date(post.data.date).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</div>
            <h3>{post.data.title}</h3>
            <p class="blog-excerpt">{post.data.excerpt}</p>
            {post.data.tags?.length > 0 && (
              <div class="blog-tags">
                {post.data.tags.map(tag => <span class="blog-tag">{tag}</span>)}
              </div>
            )}
          </div>
        </a>
      ))
    ) : (
      <p style="color: var(--text-dim); text-align: center; padding: 4rem 0;">
        No posts yet. Write your first story at <a href="/admin" style="color: var(--accent)">/admin</a>
      </p>
    )}
  </div>
</Layout>
